# Copy this file to .env and fill in values.

# --- Library / CLI: upstream LLM key (DeepInfra by default) ---
DEEPINFRA_API_KEY=your_api_key_here

# --- API gateway (preserve.api) — only needed if running the gateway ---
# Org's upstream key (never exposed to gateway clients). Falls back to DEEPINFRA_API_KEY.
# PRESERVE_UPSTREAM_API_KEY=your_upstream_key_here
# PRESERVE_UPSTREAM_BASE_URL=https://api.deepinfra.com/v1/openai
# PRESERVE_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# PRESERVE_SENSITIVITY=standard

# Gateway API keys: who may call the proxy + their limits (JSON).
# PRESERVE_API_KEYS={"sk-team-alpha":{"name":"alpha","rpm":60,"daily_token_quota":2000000}}

# Shared rate limiting across workers/hosts (optional).
# REDIS_URL=redis://redis:6379/0
